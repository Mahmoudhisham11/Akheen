# Template only — Next.js does NOT inject this file into process.env.
# Copy to ".env.local" and fill values from Cloudinary Dashboard → Settings → API Keys.
# Restart `npm run dev` after editing .env.local.
#
# Production (Netlify): Site configuration → Environment variables
# Add the same three keys with the same values as your local .env.local (secrets stay in Netlify, not in Git).
# Required for POST /api/cloudinary/delete (dashboard product image removal): CLOUDINARY_API_KEY and CLOUDINARY_API_SECRET.
# CLOUDINARY_CLOUD_NAME is optional if your build uses the default in lib/cloudinary/config.js.
# After saving variables: Deploys → Trigger deploy.

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
